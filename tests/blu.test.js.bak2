'use strict';
/**
 * BLU UAT Automation — Playwright
 * 
 * WORKING VERSION - All constants read inside test function
 * - Smart relation selection by L1 category
 * - Filter logic with env vars working correctly
 * - Thinking state detection
 * - Consent handling
 * - Mid-run relation re-selection
 */

const { test, expect } = require('@playwright/test');
const fs   = require('fs');
const path = require('path');

// ─── Load config and test cases (module level) ────────────────────────────────
const cfg = JSON.parse(fs.readFileSync(path.resolve('run_config.json'), 'utf-8'));
const allCases = JSON.parse(fs.readFileSync(path.resolve('data/blu_test_cases.json'), 'utf-8'));

// ─── Helper functions ─────────────────────────────────────────────────────────

const THINKING_PHRASES = [
  'checking', 'hold on', 'kindly wait', 'just a moment',
  'working on it', 'confirming', 'please wait', 'one moment',
  'fetching', 'loading', 'processing',
];

function isThinkingState(text) {
  const lower = text.toLowerCase().trim();
  return THINKING_PHRASES.some(p => lower.includes(p)) && lower.length < 60;
}

async function screenshot(page, label) {
  const p = `results/screenshots/${label}_${Date.now()}.png`;
  await page.screenshot({ path: p, fullPage: true }).catch(() => {});
  console.log(`  📸 ${p}`);
  return p;
}

async function clearAndType(page, locator, text) {
  await locator.waitFor({ state: 'visible', timeout: 30000 });
  await locator.scrollIntoViewIfNeeded().catch(() => {});
  await locator.click({ force: true });
  await page.keyboard.press('Meta+A');
  await page.keyboard.press('Backspace');
  await page.keyboard.type(text, { delay: 12 });
}

async function submitFromComposer(page, locator) {
  const method = await locator.evaluate(el => {
    let node = el;
    for (let i = 0; i < 9; i++) {
      const parent = node?.parentElement;
      if (!parent) break;
      for (const b of parent.querySelectorAll('button')) {
        if (!b.disabled) { b.click(); return 'button'; }
      }
      const rb = parent.querySelector('[role="button"]');
      if (rb) { rb.click(); return 'role-button'; }
      for (const img of parent.querySelectorAll('img')) {
        if (window.getComputedStyle(img).cursor === 'pointer') {
          img.click(); return 'img-pointer';
        }
      }
      const imgs = parent.querySelectorAll('img');
      if (imgs.length) { imgs[imgs.length - 1].click(); return 'img-last'; }
      node = parent;
    }
    return null;
  }).catch(() => null);
  if (!method) { await locator.press('Enter').catch(() => {}); return 'enter'; }
  return method;
}

async function dismissRetry(page) {
  const btn = page.getByRole('button', { name: /^Retry$/i }).first();
  let attempts = 0;
  while (await btn.isVisible().catch(() => false) && attempts < 5) {
    console.log(`  🟠 Retry card — dismissing (attempt ${attempts + 1})…`);
    await btn.click({ force: true });
    await page.waitForTimeout(2000);
    attempts++;
  }
}

async function isConsentPending(page) {
  return await page.evaluate(() => {
    const checkboxes = Array.from(document.querySelectorAll('input[type="checkbox"]'));
    return checkboxes.some(cb => !cb.checked);
  }).catch(() => false);
}

async function acceptConsent(page, attempt) {
  const pending = await isConsentPending(page);
  if (!pending) return false;

  console.log(`  🟦 Consent (attempt ${attempt}) — clicking checkbox…`);

  const checkbox  = page.locator('input[type="checkbox"]').first();
  const acceptBtn = page.locator('button.blu-primary-button').last();

  await checkbox.scrollIntoViewIfNeeded().catch(() => {});
  await page.waitForTimeout(300);

  const box = await checkbox.boundingBox().catch(() => null);
  if (box) {
    await page.mouse.click(box.x + box.width / 2, box.y + box.height / 2);
    console.log(`    ↳ Clicked checkbox center`);
  } else {
    await checkbox.click({ force: true }).catch(() => {});
    console.log(`    ↳ Force-clicked checkbox`);
  }
  await page.waitForTimeout(400);

  const checked = await checkbox.evaluate(el => el.checked).catch(() => false);
  console.log(`    ↳ checked=${checked}`);
  if (!checked) {
    await checkbox.evaluate(el => {
      el.checked = true;
      el.dispatchEvent(new Event('input',  { bubbles: true }));
      el.dispatchEvent(new Event('change', { bubbles: true }));
      el.dispatchEvent(new MouseEvent('click', { bubbles: true }));
    }).catch(() => {});
    await page.waitForTimeout(400);
  }

  for (let w = 0; w < 6; w++) {
    await page.waitForTimeout(500);
    if (await acceptBtn.isEnabled().catch(() => false)) {
      console.log(`    ↳ Button enabled after ${(w + 1) * 0.5}s`);
      break;
    }
  }

  await acceptBtn.scrollIntoViewIfNeeded().catch(() => {});
  await acceptBtn.click({ force: true });
  console.log(`    ↳ Clicked Accept and Continue`);
  await page.waitForTimeout(2500);
  await dismissRetry(page);
  return true;
}

async function isInitialHomeReady(page) {
  const chipsVisible = await page
    .locator('text=What you can do next').first()
    .isVisible().catch(() => false);
  if (!chipsVisible) return false;

  const composerVisible = await page
    .locator('textarea, [contenteditable="true"]').first()
    .isVisible().catch(() => false);
  if (!composerVisible) return false;

  if (await page.getByRole('button', { name: /^Retry$/i }).first()
    .isVisible().catch(() => false)) return false;

  if (await isConsentPending(page)) return false;

  return true;
}

async function waitForHome(page) {
  console.log('  ⏳ Waiting for consent or home chips…');

  await Promise.race([
    page.locator('input[type="checkbox"]').first()
      .waitFor({ state: 'attached', timeout: 15000 }),
    page.locator('text=What you can do next').first()
      .waitFor({ state: 'visible', timeout: 15000 }),
  ]).catch(() => {
    console.log('  ⚠️  Neither appeared in 15s — proceeding anyway');
  });

  for (let i = 1; i <= 20; i++) {
    await dismissRetry(page);
    if (await isInitialHomeReady(page)) {
      console.log(`  ✅ Home/Chips ready (attempt ${i})`);
      return;
    }
    if (await isConsentPending(page)) {
      await acceptConsent(page, i);
    } else {
      await page.waitForTimeout(1000);
    }
  }

  await screenshot(page, 'fail_home_not_reached');
  throw new Error('Home/Chips state not reached after 20 attempts');
}

async function selectRelationByL1(page, l1Category) {
  console.log(`  🔧 Auto-selecting relation for L1: ${l1Category}…`);
  
  await page.waitForTimeout(2000);
  
  const l1Lower = l1Category.toLowerCase();
  let targetChip = null;
  
  if (l1Lower.includes('loan')) {
    targetChip = 'Loan';
  } else if (l1Lower.includes('card')) {
    targetChip = 'Cards';
  } else if (l1Lower.includes('insurance')) {
    targetChip = 'Insurance';
  } else if (l1Lower.includes('investment') || l1Lower.includes('deposit') || l1Lower.includes('fd') || l1Lower.includes('sdp')) {
    targetChip = 'Investment';
  } else if (l1Lower.includes('bbps')) {
    console.log('    ↳ BBPS has no chip — skipping');
    return false;
  } else {
    console.log(`    ↳ Unknown L1 — trying first available chip`);
    targetChip = null;
  }
  
  const needsRelation = await page.evaluate(() => {
    return document.body.innerText.includes('Please select the relation') ||
           document.body.innerText.includes('select the product to move further');
  }).catch(() => false);
  
  if (!needsRelation) {
    console.log('    ↳ No relation selection needed');
    return false;
  }
  
  const clicked = await page.evaluate((target) => {
    const allDivs = Array.from(document.querySelectorAll('div, button'));
    
    for (const el of allDivs) {
      const text = el.innerText || '';
      const isClickable = window.getComputedStyle(el).cursor === 'pointer' || 
                          el.tagName === 'BUTTON' ||
                          el.onclick;
      
      if (!isClickable) continue;
      
      if (target && text.trim() === target) {
        el.click();
        return target;
      }
      
      if (!target && (
        text.includes('Loan') ||
        text.includes('Cards') ||
        text.includes('Insurance') ||
        text.includes('Investment') ||
        text.includes('Active') ||
        text.includes('PERSONAL LOAN') ||
        text.includes('EMI CARD')
      )) {
        el.click();
        return text.trim().slice(0, 20);
      }
    }
    return null;
  }, targetChip).catch(() => null);
  
  if (clicked) {
    console.log(`    ↳ Clicked chip: "${clicked}"`);
    await page.waitForTimeout(3000);
    await dismissRetry(page);
    return true;
  } else {
    console.log('    ↳ No matching chip found');
    return false;
  }
}

async function botMessageCount(page) {
  return page.locator('.blu-bot-message.message').count().catch(() => 0);
}

async function waitForFinalBotReply(page, beforeCount, BOT_TIMEOUT) {
  const deadline = Date.now() + BOT_TIMEOUT;

  await expect.poll(() => botMessageCount(page), {
    timeout: BOT_TIMEOUT,
    intervals: [300, 500, 800, 1000],
  }).toBeGreaterThan(beforeCount);

  let lastText = '';
  let stableCount = 0;

  while (Date.now() < deadline) {
    await page.waitForTimeout(1000);

    const last    = page.locator('.blu-bot-message.message').last();
    const current = (await last.innerText().catch(() => '')).trim();

    if (!current) {
      stableCount = 0;
      lastText = current;
      continue;
    }

    if (isThinkingState(current)) {
      console.log(`    ⏳ Bot thinking: "${current}"`);
      stableCount = 0;
      lastText = current;
      continue;
    }

    if (current === lastText) {
      stableCount++;
      if (stableCount >= 2) {
        return current;
      }
    } else {
      stableCount = 1;
      lastText = current;
    }
  }

  return lastText;
}

function scoreResult(tc, botReply) {
  const reply     = botReply.toLowerCase();
  const keywords  = (tc.expected_keywords || '').split('|').map(k => k.trim().toLowerCase()).filter(Boolean);
  const matchedKw = keywords.filter(k => reply.includes(k));
  const responseMatch = keywords.length === 0 ? 'Pass' :
    (matchedKw.length >= Math.ceil(keywords.length * 0.4) ? 'Pass' : 'Fail');

  let ctaPresent = 'N/A';
  if (tc.cta_expected === 'Yes') {
    const ctaLabel = (tc.cta_label || '').toLowerCase();
    ctaPresent = (ctaLabel && reply.includes(ctaLabel)) ||
      reply.includes('click here') || reply.includes('tap here') ||
      reply.includes('raise a request') ? 'Pass' : 'Fail';
  }

  let ctaTypeCorrect = 'N/A';
  if (tc.cta_expected === 'Yes' && tc.cta_type) {
    ctaTypeCorrect = ctaPresent === 'Pass' ? 'Pass' : 'Fail';
  }

  const checks  = [responseMatch, ctaPresent, ctaTypeCorrect].filter(v => v !== 'N/A');
  const overall = checks.every(v => v === 'Pass') ? 'Pass' : 'Fail';
  return { responseMatch, ctaPresent, ctaTypeCorrect, overall, matchedKw: matchedKw.join(', ') };
}

// ─── Main test ────────────────────────────────────────────────────────────────

test('BLU UAT — Batch Run', async ({ page, context }) => {
  // Read env vars INSIDE test function so they're set when Playwright runs
  const BLU_URL     = process.env.BLU_URL         || cfg.BLU_URL;
  const BLU_MOBILE  = process.env.BLU_MOBILE      || cfg.BLU_MOBILE;
  const BLU_OTP     = process.env.BLU_OTP         || cfg.BLU_OTP;
  const BATCH_SIZE  = parseInt(process.env.BATCH_SIZE      || cfg.BATCH_SIZE);
  const FILTER_L1   = process.env.FILTER_L1       || cfg.FILTER_L1        || '';
  const FILTER_VAR  = process.env.FILTER_VARIATION || cfg.FILTER_VARIATION || '';
  const DELAY_MS    = parseInt(process.env.DELAY_MS || cfg.DELAY_BETWEEN_MSGS_MS);
  const BOT_TIMEOUT = parseInt(cfg.BOT_REPLY_TIMEOUT_MS);

  // Apply filters
  let filtered = allCases;
  
  if (FILTER_L1) {
    filtered = filtered.filter(tc => tc.l1.toLowerCase() === FILTER_L1.toLowerCase());
  }
  
  if (FILTER_VAR) {
    filtered = filtered.filter(tc => tc.variation_type === FILTER_VAR);
  }
  
  filtered = filtered.slice(0, BATCH_SIZE);

  console.log(`DEBUG: allCases.length = ${allCases.length}`);
  console.log(`DEBUG: FILTER_L1 = "${FILTER_L1}"`);
  console.log(`DEBUG: filtered.length after L1 filter = ${filtered.length}`);
  
  console.log(`\n📋 Loaded ${filtered.length} test cases for this run`);
  console.log(`   Filter L1: ${FILTER_L1 || 'ALL'} | Variation: ${FILTER_VAR || 'ALL'} | Batch Size: ${BATCH_SIZE}`);
  
  if (filtered.length === 0) {
    console.log('⚠️  No test cases matched filters');
    return;
  }

  // Setup results tracking
  fs.mkdirSync('results', { recursive: true });
  fs.mkdirSync('results/screenshots', { recursive: true });
  const RUN_TS       = new Date().toISOString().replace(/[:.]/g, '-');
  const RESULTS_FILE = `results/run_${RUN_TS}.json`;
  
  const runResults = { 
    run_ts: RUN_TS, 
    config: cfg, 
    filter_l1: FILTER_L1,
    filter_variation: FILTER_VAR,
    total: filtered.length, 
    results: [] 
  };

  await context.grantPermissions(['geolocation'], { origin: new URL(BLU_URL).origin });
  await context.setGeolocation({ latitude: 18.5204, longitude: 73.8567 });

  console.log(`\n🚀 ${BLU_URL}`);
  await page.goto(BLU_URL, { waitUntil: 'domcontentloaded', timeout: 60000 });
  await page.waitForTimeout(2000);
  await dismissRetry(page);

  console.log('🔐 Entering mobile…');
  const mobileBox = page.getByRole('textbox', { name: /enter your mobile number/i }).first();
  await mobileBox.waitFor({ state: 'visible', timeout: 40000 });
  await clearAndType(page, mobileBox, BLU_MOBILE);
  console.log(`  ↳ Submit: ${await submitFromComposer(page, mobileBox)}`);

  let otpReady = false;
  for (let attempt = 1; attempt <= 3; attempt++) {
    await page.waitForTimeout(3000);
    const retryBtn = page.getByRole('button', { name: /^Retry$/i }).first();
    if (await retryBtn.isVisible().catch(() => false)) {
      console.log(`  🟠 Retry after mobile (attempt ${attempt})…`);
      await retryBtn.click({ force: true });
      await page.waitForTimeout(2000);
      const mb2 = page.getByRole('textbox', { name: /enter your mobile number/i }).first();
      if (await mb2.isVisible().catch(() => false)) {
        await clearAndType(page, mb2, BLU_MOBILE);
        console.log(`  ↳ Re-submit: ${await submitFromComposer(page, mb2)}`);
      }
      continue;
    }
    const otpVisible =
      await page.locator('text=/please provide your 6.?digit otp/i').first()
        .isVisible().catch(() => false) ||
      await page.getByRole('textbox', { name: /otp|6.?digit/i }).first()
        .isVisible().catch(() => false);
    if (otpVisible) { otpReady = true; break; }
    await page.waitForTimeout(2000);
  }

  if (!otpReady) {
    await Promise.race([
      page.locator('text=/please provide your 6.?digit otp/i').first()
        .waitFor({ state: 'visible', timeout: 20000 }),
      page.getByRole('textbox', { name: /otp|6.?digit/i }).first()
        .waitFor({ state: 'visible', timeout: 20000 }),
    ]).catch(async () => {
      await screenshot(page, 'fail_otp_not_appeared');
      throw new Error('OTP not appeared');
    });
  }

  console.log('🔐 Entering OTP…');
  await dismissRetry(page);
  const otpBox    = page.getByRole('textbox', { name: /otp|6.?digit/i }).first();
  const otpTarget = await otpBox.count().catch(() => 0)
    ? otpBox : page.locator('textarea[placeholder*="otp" i]').first();
  await otpTarget.waitFor({ state: 'visible', timeout: 20000 });
  await clearAndType(page, otpTarget, BLU_OTP);
  console.log(`  ↳ Submit: ${await submitFromComposer(page, otpTarget)}`);

  await page.locator('text=/otp has been successfully validated/i').first()
    .waitFor({ state: 'visible', timeout: 35000 })
    .catch(async () => {
      await screenshot(page, 'fail_otp_not_validated');
      throw new Error('OTP not validated');
    });
  console.log('✅ OTP validated');

  console.log('⏳ Clearing consent + waiting for home…');
  await waitForHome(page);

  // Smart relation selection using first test case's L1
  if (filtered.length > 0) {
    await selectRelationByL1(page, filtered[0].l1);
  }

  const composer = page.locator('textarea, [contenteditable="true"]').first();
  await composer.waitFor({ state: 'visible', timeout: 30000 });
  console.log(`\n✅ Ready. Running ${filtered.length} test cases…\n`);

  let passed = 0, failed = 0;

  for (let i = 0; i < filtered.length; i++) {
    const tc = filtered[i];
    console.log(`\n[${i + 1}/${filtered.length}] ${tc.id} | ${tc.variation_type}`);
    console.log(`  L2: ${tc.l2} | L3: ${tc.l3} | State: ${tc.data_state}`);
    console.log(`  💬 "${tc.utterance}"`);

    await dismissRetry(page);
    if (await isConsentPending(page)) {
      console.log('  🟦 New consent — accepting…');
      await acceptConsent(page, 1);
      await page.waitForTimeout(1000);
    }

    // Mid-run relation check - if bot asks again, re-select based on THIS TC's L1
    await selectRelationByL1(page, tc.l1);

    await composer.waitFor({ state: 'visible', timeout: 30000 });

    const beforeCount = await botMessageCount(page);
    const startTime   = Date.now();

    await clearAndType(page, composer, tc.utterance);
    await submitFromComposer(page, composer);

    let botReply = '';
    let timedOut = false;
    try {
      botReply = await waitForFinalBotReply(page, beforeCount, BOT_TIMEOUT);
      if (!botReply) {
        timedOut = true;
        await screenshot(page, `timeout_${tc.id}`);
      }
    } catch {
      timedOut = true;
      await screenshot(page, `timeout_${tc.id}`);
    }

    const elapsed = Date.now() - startTime;
    const scores  = timedOut
      ? { responseMatch: 'Fail', ctaPresent: 'N/A', ctaTypeCorrect: 'N/A', overall: 'Fail', matchedKw: '' }
      : scoreResult(tc, botReply);

    if (scores.overall === 'Pass') passed++; else failed++;
    const icon = scores.overall === 'Pass' ? '✅' : '❌';
    console.log(`  🤖 (${elapsed}ms): ${botReply.slice(0, 150).replace(/\n/g, ' ')}${botReply.length > 150 ? '…' : ''}`);
    console.log(`  ${icon} ${scores.overall} | Response:${scores.responseMatch} | CTA:${scores.ctaPresent} | CTAType:${scores.ctaTypeCorrect}`);

    runResults.results.push({
      tc_id:             tc.id,
      variation_type:    tc.variation_type,
      l1:                tc.l1,
      l2:                tc.l2,
      l3:                tc.l3,
      data_state:        tc.data_state,
      utterance:         tc.utterance,
      bot_reply:         botReply.slice(0, 500),
      timed_out:         timedOut,
      elapsed_ms:        elapsed,
      expected_keywords: tc.expected_keywords,
      cta_expected:      tc.cta_expected,
      cta_type:          tc.cta_type,
      cta_label:         tc.cta_label,
      response_match:    scores.responseMatch,
      cta_present:       scores.ctaPresent,
      cta_type_correct:  scores.ctaTypeCorrect,
      overall:           scores.overall,
      matched_keywords:  scores.matchedKw,
    });

    fs.writeFileSync(RESULTS_FILE, JSON.stringify(runResults, null, 2));
    await page.waitForTimeout(DELAY_MS);
  }

  runResults.passed    = passed;
  runResults.failed    = failed;
  runResults.pass_rate = `${((passed / filtered.length) * 100).toFixed(1)}%`;
  fs.writeFileSync(RESULTS_FILE, JSON.stringify(runResults, null, 2));

  console.log(`\n${'═'.repeat(60)}`);
  console.log(`✅ Passed: ${passed}  ❌ Failed: ${failed}  Pass Rate: ${runResults.pass_rate}`);
  console.log(`📄 Results saved: ${RESULTS_FILE}`);
  console.log(`${'═'.repeat(60)}\n`);
});
